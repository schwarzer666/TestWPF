<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:TemperatureCharacteristics.ViewModels"
                    xmlns:models="clr-namespace:TemperatureCharacteristics.Models"
					xmlns:controls="clr-namespace:TemperatureCharacteristics.Views.Controls">
	<DataTemplate x:Key="VITabContentTemplate">
		<Grid 
			IsEnabled="{Binding DataContext.IsSmallTabCtrlEnabled, 
			RelativeSource={RelativeSource AncestorType=TabControl}}"
            Background="#FFE5E5E5">
			<Grid.Resources>
				<!--TargetType="Controlでは反映されない為個別でStyleを定義"TextBox, ComboBox, CheckBox, Button-->
				<Style TargetType="TextBox">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="10"/>
					<Setter Property="Margin" Value="5,0,0,0"/>
					<Setter Property="Width" Value="35"/>
				</Style>
				<Style TargetType="ComboBox">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="10"/>
				</Style>
				<Style TargetType="CheckBox">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="11"/>
				</Style>
				<Style TargetType="Button">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="11"/>
				</Style>
				<Style TargetType="Label">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="11"/>
                    <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
					<Setter Property="ToolTipService.ShowDuration" Value="5000" />
				</Style>
                <Style TargetType="GroupBox">
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                    <Setter Property="VerticalAlignment" Value="Top"/>
                    <Setter Property="FontSize" Value="10"/>
                </Style>
            </Grid.Resources>
			<!--VI Tab内 14行×9列-->
			<Grid.RowDefinitions>
				<RowDefinition Height="30"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="50*"/>
				<ColumnDefinition Width="75"/>
				<ColumnDefinition Width="45*"/>
				<ColumnDefinition Width="62*"/>
				<ColumnDefinition Width="40"/>
				<ColumnDefinition Width="50*"/>
				<ColumnDefinition Width="65"/>
				<ColumnDefinition Width="40"/>
				<ColumnDefinition Width="53*"/>
			</Grid.ColumnDefinitions>
			<!--測定対象設定-->
			<CheckBox 
				Content="測定" 
				IsChecked="{Binding MeasureOn, Mode=TwoWay}"
				Margin="2,0,0,0"
				Grid.Row="0" Grid.Column="0"/>
			<TextBox 
				Text="{Binding ItemHeader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
				Margin="2,0,2,0"
				Width="65"
				Grid.Row="0" Grid.Column="1"/>
			<!--電源設定-->
			<GroupBox
				Header="電源設定" 
				Background="LightBlue"
				Margin="0"
				Grid.Row="1" Grid.Column="0"
				Grid.RowSpan="6" Grid.ColumnSpan="6">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="50*"/>
						<ColumnDefinition Width="75"/>
						<ColumnDefinition Width="45*"/>
						<ColumnDefinition Width="62*"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="50*"/>
					</Grid.ColumnDefinitions>
					<Label 
						Content="Action"  
						Margin="5,0,0,0"
						Grid.Row="0" Grid.Column="1"/>
					<Label 
						Content="Mode"
						Margin="1,0,0,0"
						Grid.Row="0" Grid.Column="2"/>
					<Label 
						Content="Range"  
						Margin="5,0,0,0"
						Grid.Row="0" Grid.Column="3"/>
					<Label 
						Content="Limit(空白=default)" 
						FontSize="9"
						Grid.Row="0" Grid.Column="4"
						Grid.ColumnSpan="2"/>
					<Label 
						Content="電源1" 
						IsEnabled="{Binding SourceConfig.SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="5,0,0,0"
						Grid.Row="1" Grid.Column="0"/>
					<ComboBox  
						ItemsSource="{StaticResource ComboItems_Func}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceFunc1Index, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="75"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceMode1Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="40"
						Grid.Row="1" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceRang1Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="0" 
						Width="60"
						Grid.Row="1" Grid.Column="3"/>
					<TextBox 
						Text="{Binding SourceConfig.SourceLimit1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						IsEnabled="{Binding SourceConfig.SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Grid.Row="1" Grid.Column="4"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceLimit}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceLimit1Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="45"
						Grid.Row="1" Grid.Column="5"/>
					<Label 
						Content="電源2" 
						IsEnabled="{Binding SourceConfig.SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="5,0,0,0"
						Grid.Row="2" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Func}" 
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceFunc2Index, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="75"
						Grid.Row="2" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceMode2Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="40"
						Grid.Row="2" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceRang}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceRang2Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="0" 
						Width="60"
						Grid.Row="2" Grid.Column="3"/>
					<TextBox 
						Text="{Binding SourceConfig.SourceLimit2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						IsEnabled="{Binding SourceConfig.SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Grid.Row="2" Grid.Column="4"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceLimit}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceLimit2Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="45"
						Grid.Row="2" Grid.Column="5"/>
					<Label 
						Content="電源3" 
						IsEnabled="{Binding SourceConfig.SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="5,0,0,0"
						Grid.Row="3" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Func}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceFunc3Index, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="75"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceMode3Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0"  
						Width="40"
						Grid.Row="3" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceRang}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceRang3Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="0" 
						Width="60"
						Grid.Row="3" Grid.Column="3"/>
					<TextBox 
						Text="{Binding SourceConfig.SourceLimit3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						IsEnabled="{Binding SourceConfig.SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Grid.Row="3" Grid.Column="4"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceLimit}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceLimit3Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="45"
						Grid.Row="3" Grid.Column="5"/>
					<Label 
						Content="電源4"
						IsEnabled="{Binding SourceConfig.SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="5,0,0,0"
						Grid.Row="4" Grid.Column="0"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Func}" 
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceFunc4Index, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="75"
						Grid.Row="4" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceMode4Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="40"
						Grid.Row="4" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceRang}" 
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceRang4Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="0"  
						Width="60"
						Grid.Row="4" Grid.Column="3"/>
					<TextBox 
						Text="{Binding SourceConfig.SourceLimit4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						IsEnabled="{Binding SourceConfig.SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Grid.Row="4" Grid.Column="4"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceLimit}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceConfig.SourceLimit4Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceConfig.SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="45"
						Grid.Row="4" Grid.Column="5"/>
				</Grid>
			</GroupBox>
			<!--Const設定-->
			<GroupBox
				Header="Const設定" 
				Background="LightBlue"
				Margin="0"
				Grid.Row="2" Grid.Column="6"
				Grid.RowSpan="5" Grid.ColumnSpan="3"
				Panel.ZIndex="0">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="60"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="53*"/>
					</Grid.ColumnDefinitions>
					<Label 
						Content="Const値1"  
						Margin="0"
						Grid.Row="0" Grid.Column="0"/>
					<TextBox  
						Text="{Binding ConstConfig.Const1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="0" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Units}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding ConstConfig.Const1UnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="45"
						Grid.Row="0" Grid.Column="2"/>
					<Label 
						Content="Const値2"  
						Margin="0"
						Grid.Row="1" Grid.Column="0"/>
					<TextBox  
						Text="{Binding ConstConfig.Const2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Units}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding ConstConfig.Const2UnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="45"
						Grid.Row="1" Grid.Column="2"/>
					<Label 
						Content="Const値3"  
						Margin="0"
						Grid.Row="2" Grid.Column="0"/>
					<TextBox  
						Text="{Binding ConstConfig.Const3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="2" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Units}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding ConstConfig.Const3UnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="45"
						Grid.Row="2" Grid.Column="2"/>
					<Label 
						Content="Const値4"  
						Margin="0"
						Grid.Row="3" Grid.Column="0"/>
					<TextBox  
						Text="{Binding ConstConfig.Const4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Units}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding ConstConfig.Const4UnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="45"
						Grid.Row="3" Grid.Column="2"/>
				</Grid>
			</GroupBox>
			<!--初期電圧設定-->
			<GroupBox
				Header="初期電圧設定" 
				Background="LightPink"
				Margin="0"
				Grid.Row="7" Grid.Column="6"
				Grid.RowSpan="4" Grid.ColumnSpan="3">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="62*"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="50*"/>
					</Grid.ColumnDefinitions>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Source}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectReleaseConfig.DetectSourceAIndex, Mode=TwoWay}"
						Margin="0"
						Width="55"
						Grid.Row="0" Grid.Column="0"/>
					<TextBox
						Text="{Binding DetectReleaseConfig.DetectReleaseA, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="0" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Units}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectReleaseConfig.DetectUnitAIndex, Mode=TwoWay}"
						Margin="0"
						Width="45"
						Grid.Row="0" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Source}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectReleaseConfig.DetectSourceBIndex, Mode=TwoWay}"
						Margin="0"
						Width="55"
						Grid.Row="1" Grid.Column="0"/>
					<TextBox
						Text="{Binding DetectReleaseConfig.DetectReleaseB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Units}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectReleaseConfig.DetectUnitBIndex, Mode=TwoWay}"
						Margin="0"
						Width="45"
						Grid.Row="1" Grid.Column="2"/>
					<Label 
						Content="保持時間" 
						Margin="0"
						Grid.Row="2" Grid.Column="0"/>
					<TextBox
						Text="{Binding DetectReleaseConfig.CheckTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_tUnits}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectReleaseConfig.CheckTimeUnitIndex, Mode=TwoWay}"
						Margin="0"
						Width="45"
						Grid.Row="3" Grid.Column="2"/>
				</Grid>
			</GroupBox>
			<!--Measure設定-->
			<GroupBox
				Header="Measure設定(VI)" 
				Background="LightYellow"
				Margin="0"
				Grid.Row="12" Grid.Column="6"
				Grid.RowSpan="2" Grid.ColumnSpan="3">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="60"/>
						<ColumnDefinition Width="45"/>
						<ColumnDefinition Width="53*"/>
					</Grid.ColumnDefinitions>
					<Grid.ToolTip>
						<ToolTip>
							<TextBlock>
							初期電圧設定経過後、VI測定までの開始時間を入力
							</TextBlock>
						</ToolTip>
					</Grid.ToolTip>
					<Label 
						Content="Stanby"  
						Margin="0"
						Grid.Row="1" Grid.Column="0"/>
					<TextBox  
						Text="{Binding VIConfig.StanbyValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox  
						ItemsSource="{StaticResource ComboItems_tUnits}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding VIConfig.StanbyUnitIndex, Mode=TwoWay}"
						Margin="0" 
						Width="40"
						Grid.Row="1" Grid.Column="3"/>
				</Grid>
			</GroupBox>
			<!--DMM設定 (Normal Sweep時表示)-->
			<GroupBox 
				Header="DMM設定" 
				Background="SkyBlue"
				Grid.Row="7" Grid.Column="0"
				Grid.RowSpan="7" Grid.ColumnSpan="6">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="50"/>
						<ColumnDefinition Width="55"/>
						<ColumnDefinition Width="55"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="50"/>
					</Grid.ColumnDefinitions>
					<Label 
						Content="Measure"  
						Margin="0"
						Grid.Row="0" Grid.Column="1"/>
					<Label 
						Content="Range"  
						Margin="0"
						Grid.Row="0" Grid.Column="2"/>
					<Label 
						Content="NPLC"  
						Margin="0"
						Grid.Row="0" Grid.Column="3"/>
					<Label 
						Content="Disp.ON"  
						Margin="0"
						Grid.Row="0" Grid.Column="4"/>
					<Label 
						Content="DMM1"
						Grid.Row="1" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasMode1Index, Mode=TwoWay, FallbackValue=0}" 
						Margin="5,0,0,0"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasRang1Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="1" Grid.Column="2"/>
					<TextBox 
						Text="{Binding DmmConfig.Meas1plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="3"/>
					<CheckBox 
						IsChecked="{Binding DmmConfig.Meas1DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="1" Grid.Column="4"/>
					<Label 
						Content="DMM2"  
						Grid.Row="2" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasMode2Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="2" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasRang2Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="2" Grid.Column="2"/>
					<TextBox 
						Text="{Binding DmmConfig.Meas2plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="2" Grid.Column="3"/>
					<CheckBox 
						IsChecked="{Binding DmmConfig.Meas2DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="2" Grid.Column="4"/>
					<Label 
						Content="DMM3"  
						Grid.Row="3" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasMode3Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasRang3Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="3" Grid.Column="2"/>
					<TextBox
						Text="{Binding DmmConfig.Meas3plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="3" Grid.Column="3"/>
					<CheckBox
						IsChecked="{Binding DmmConfig.Meas3DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="3" Grid.Column="4"/>
					<Label 
						Content="DMM4"  
						Grid.Row="4" Grid.Column="0"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Mode}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasMode4Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="4" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasRang4Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="4" Grid.Column="2"/>
					<TextBox
						Text="{Binding DmmConfig.Meas4plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="4" Grid.Column="3"/>
					<CheckBox
						IsChecked="{Binding DmmConfig.Meas4DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="4" Grid.Column="4"/>
					<Label 
						Content="TRIG"  
						Grid.Row="5" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_dmmTrigSource}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasTrigIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="5" Grid.Column="1"
						Grid.ColumnSpan="2"/>
				</Grid>
			</GroupBox>
			<!--Save,Load,プリセットボタン-->
			<Grid
				Grid.Row="15" Grid.Column="0"
				Grid.ColumnSpan="9">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="100"/>
				</Grid.ColumnDefinitions>
				<Button 
					x:Name="SaveButton"
					Content="測定条件Save"
					Command="{Binding DataContext.OpenSavePopupCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
					CommandParameter="{Binding}"
					Style="{StaticResource CardButtonStyle}"
					Width="90" 
					Height="40"
					Margin="5"
					Grid.Row="0" Grid.Column="0"/>
				<Button
					x:Name="LoadButton"
					Content="測定条件Load"
					Command="{Binding DataContext.OpenLoadPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
					Style="{StaticResource CardButtonStyle}"
					Width="90"
					Height="40"
					Margin="5"
					Grid.Row="0" Grid.Column="1"/>
				<Button
					x:Name ="PresetButton"
					Content="プリセット一覧"
					Command="{Binding DataContext.OpenPresetPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
					CommandParameter="{Binding}"
					Style="{StaticResource CardButtonStyle}"
					Width="90"
					Height="40"
					Margin="5"
					Grid.Row="0" Grid.Column="2"/>

				<!-- ポップアップ -->
				<!-- SaveButton -->
				<Popup 
					IsOpen="{Binding DataContext.IsSavePopupOpen, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
					PlacementTarget="{Binding ElementName=SaveButton}"
					Placement="Right"
					AllowsTransparency="True"
					PopupAnimation="Slide"
					HorizontalOffset="5">
					<Border Background="#FAFAFA"
							BorderBrush="#CCCCCC"
							BorderThickness="1" 
							CornerRadius="8" 
							Padding="12"
							Effect="{StaticResource PopupShadow}">
						<StackPanel Width="200">
							<TextBlock Text="保存操作" 
									   FontWeight="Bold" 
									   Margin="5,0,5,10"
									   Foreground="#444"/>
							<UniformGrid Columns="1" Rows="2">
								<Button 
									Content="このタブのみSave"
									Command="{Binding DataContext.SaveUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
									CommandParameter="{Binding}"
									Style="{StaticResource CardButtonStyle}"
									Width="160"
									Margin="5"/>
								<Button 
									Content="全タブSave"
									Command="{Binding DataContext.SaveAllUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
									CommandParameter="{Binding}"
									Style="{StaticResource CardButtonStyle}"
									Width="160"
									Margin="5"/>
							</UniformGrid>
						</StackPanel>
					</Border>
				</Popup>
				<!-- LoadButton -->
				<Popup 
					IsOpen="{Binding DataContext.IsLoadPopupOpen, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
					PlacementTarget="{Binding ElementName=LoadButton}"
					Placement="Right"
					AllowsTransparency="True"
					PopupAnimation="Slide"
					HorizontalOffset="5">
					<Border Background="White" 
                        BorderBrush="Gray" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="10">
						<StackPanel>
							<Button 
								Content="このタブにLoad"
								Command="{Binding DataContext.LoadUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
								CommandParameter="{Binding}" 
								Margin="5"/>
							<Button 
								Content="全タブLoad"
								Command="{Binding DataContext.LoadAllUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
								CommandParameter="{Binding}"
								Margin="5"/>
						</StackPanel>
					</Border>
				</Popup>
				<!-- Preset -->
				<Popup 
					IsOpen="{Binding DataContext.IsPresetPopupOpen, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
					PlacementTarget="{Binding ElementName=PresetButton}"
					Placement="Right"
					AllowsTransparency="True"
					PopupAnimation="Slide"
					HorizontalOffset="5">
					<Border Background="White" 
                        BorderBrush="Gray" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="10">
						<ScrollViewer 
							MaxHeight="200" 
							VerticalScrollBarVisibility="Auto">
							<StackPanel>
								<ItemsControl ItemsSource="{Binding DataContext.FilteredPresetButtons, RelativeSource={RelativeSource AncestorType=Window}}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Button 
												Content="{Binding Name}" 
												Command="{Binding DataContext.SelectPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
												CommandParameter="{Binding}"
												Tag="{Binding Id}"
												Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}}"
												Margin="5,2" 
												Width="120"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</ScrollViewer>
					</Border>
				</Popup>
			</Grid>
		</Grid>
	</DataTemplate>
</ResourceDictionary>