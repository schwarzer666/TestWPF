<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:TemperatureCharacteristics.ViewModels"
                    xmlns:models="clr-namespace:TemperatureCharacteristics.Models">
	<DataTemplate x:Key="VITabContentTemplate">
		<Grid 
			IsEnabled="{Binding DataContext.IsSmallTabCtrlEnabled, 
			RelativeSource={RelativeSource AncestorType=TabControl}}"
            Background="#FFE5E5E5">
			<Grid.Resources>
				<!--TargetType="Controlでは反映されない為個別でStyleを定義"TextBox, ComboBox, CheckBox, Button-->
				<Style TargetType="TextBox">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="10"/>
					<Setter Property="Margin" Value="5,0,0,0"/>
					<Setter Property="Width" Value="35"/>
				</Style>
				<Style TargetType="ComboBox">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="10"/>
				</Style>
				<Style TargetType="CheckBox">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="11"/>
				</Style>
				<Style TargetType="Button">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="11"/>
				</Style>
				<Style TargetType="Label">
					<Setter Property="HorizontalAlignment" Value="Left"/>
					<Setter Property="VerticalAlignment" Value="Center"/>
					<Setter Property="FontSize" Value="11"/>
                    <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
					<Setter Property="ToolTipService.ShowDuration" Value="5000" />
				</Style>
                <Style TargetType="GroupBox">
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                    <Setter Property="VerticalAlignment" Value="Top"/>
                    <Setter Property="FontSize" Value="10"/>
                </Style>
            </Grid.Resources>
			<!--VI Tab内 14行×9列-->
			<Grid.RowDefinitions>
				<RowDefinition Height="30"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="25"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="50*"/>
				<ColumnDefinition Width="75"/>
				<ColumnDefinition Width="45*"/>
				<ColumnDefinition Width="62*"/>
				<ColumnDefinition Width="40"/>
				<ColumnDefinition Width="50*"/>
				<ColumnDefinition Width="65"/>
				<ColumnDefinition Width="40"/>
				<ColumnDefinition Width="53*"/>
			</Grid.ColumnDefinitions>
			<!--測定対象設定-->
			<CheckBox 
				Content="測定" 
				IsChecked="{Binding MeasureOn, Mode=TwoWay}"
				Margin="2,0,0,0"
				Grid.Row="0" Grid.Column="0"/>
			<TextBox 
				Text="{Binding ItemHeader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
				Margin="2,0,2,0"
				Width="65"
				Grid.Row="0" Grid.Column="1"/>
			<!--電源設定-->
			<GroupBox
				Header="電源設定" 
				Background="LightBlue"
				Margin="0"
				Grid.Row="1" Grid.Column="0"
				Grid.RowSpan="6" Grid.ColumnSpan="6">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="50*"/>
						<ColumnDefinition Width="75"/>
						<ColumnDefinition Width="45*"/>
						<ColumnDefinition Width="62*"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="50*"/>
					</Grid.ColumnDefinitions>
					<Label 
						Content="Action"  
						Margin="5,0,0,0"
						Grid.Row="0" Grid.Column="1"/>
					<Label 
						Content="Mode"
						Margin="1,0,0,0"
						Grid.Row="0" Grid.Column="2"/>
					<Label 
						Content="Range"  
						Margin="5,0,0,0"
						Grid.Row="0" Grid.Column="3"/>
					<Label 
						Content="Limit(空白=default)" 
						FontSize="9"
						Grid.Row="0" Grid.Column="4"
						Grid.ColumnSpan="2"/>
					<Label 
						Content="電源1" 
						IsEnabled="{Binding SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="5,0,0,0"
						Grid.Row="1" Grid.Column="0"/>
					<ComboBox  
						ItemsSource="{StaticResource ComboItems_Func}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceFunc1Index, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="75"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceMode1Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="40"
						Grid.Row="1" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceRang1Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="0" 
						Width="60"
						Grid.Row="1" Grid.Column="3"/>
					<TextBox 
						Text="{Binding SourceLimit1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						IsEnabled="{Binding SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Grid.Row="1" Grid.Column="4"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceLimit}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceLimit1Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc1Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="45"
						Grid.Row="1" Grid.Column="5"/>
					<Label 
						Content="電源2" 
						IsEnabled="{Binding SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="5,0,0,0"
						Grid.Row="2" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Func}" 
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding SourceFunc2Index, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="75"
						Grid.Row="2" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceMode2Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="40"
						Grid.Row="2" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceRang}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceRang2Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="0" 
						Width="60"
						Grid.Row="2" Grid.Column="3"/>
					<TextBox 
						Text="{Binding SourceLimit2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						IsEnabled="{Binding SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Grid.Row="2" Grid.Column="4"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceLimit}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceLimit2Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc2Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="45"
						Grid.Row="2" Grid.Column="5"/>
					<Label 
						Content="電源3" 
						IsEnabled="{Binding SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="5,0,0,0"
						Grid.Row="3" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Func}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceFunc3Index, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="75"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding SourceMode3Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0"  
						Width="40"
						Grid.Row="3" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceRang}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceRang3Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="0" 
						Width="60"
						Grid.Row="3" Grid.Column="3"/>
					<TextBox 
						Text="{Binding SourceLimit3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						IsEnabled="{Binding SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Grid.Row="3" Grid.Column="4"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceLimit}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceLimit3Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc3Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="45"
						Grid.Row="3" Grid.Column="5"/>
					<Label 
						Content="電源4"
						IsEnabled="{Binding SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="5,0,0,0"
						Grid.Row="4" Grid.Column="0"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Func}" 
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding SourceFunc4Index, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="75"
						Grid.Row="4" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceMode4Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="40"
						Grid.Row="4" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceRang}" 
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding SourceRang4Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="0"  
						Width="60"
						Grid.Row="4" Grid.Column="3"/>
					<TextBox 
						Text="{Binding SourceLimit4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						IsEnabled="{Binding SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Grid.Row="4" Grid.Column="4"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_SourceLimit}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding SourceLimit4Index, Mode=TwoWay, FallbackValue=0}"
						IsEnabled="{Binding SourceFunc4Index, Converter={StaticResource SourceFuncIndexToEnabledConverter}}"
						Margin="1,0,0,0" 
						Width="45"
						Grid.Row="4" Grid.Column="5"/>
				</Grid>
			</GroupBox>
			<!--Const設定-->
			<GroupBox
				Header="Const設定" 
				Background="LightBlue"
				Margin="0"
				Grid.Row="2" Grid.Column="6"
				Grid.RowSpan="5" Grid.ColumnSpan="3"
				Panel.ZIndex="0">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="60"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="53*"/>
					</Grid.ColumnDefinitions>
					<Label 
						Content="Const値1"  
						Margin="0"
						Grid.Row="0" Grid.Column="0"/>
					<TextBox  
						Text="{Binding Const1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="0" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Units}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding Const1UnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="45"
						Grid.Row="0" Grid.Column="2"/>
					<Label 
						Content="Const値2"  
						Margin="0"
						Grid.Row="1" Grid.Column="0"/>
					<TextBox  
						Text="{Binding Const2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Units}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding Const2UnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="45"
						Grid.Row="1" Grid.Column="2"/>
					<Label 
						Content="Const値3"  
						Margin="0"
						Grid.Row="2" Grid.Column="0"/>
					<TextBox  
						Text="{Binding Const3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="2" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Units}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding Const3UnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="45"
						Grid.Row="2" Grid.Column="2"/>
					<Label 
						Content="Const値4"  
						Margin="0"
						Grid.Row="3" Grid.Column="0"/>
					<TextBox  
						Text="{Binding Const4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Units}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding Const4UnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="45"
						Grid.Row="3" Grid.Column="2"/>
				</Grid>
			</GroupBox>
			<!--初期電圧設定-->
			<GroupBox
				Header="初期電圧設定" 
				Background="LightPink"
				Margin="0"
				Grid.Row="7" Grid.Column="6"
				Grid.RowSpan="4" Grid.ColumnSpan="3">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="62*"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="50*"/>
					</Grid.ColumnDefinitions>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Source}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectSourceAIndex, Mode=TwoWay}"
						Margin="0"
						Width="55"
						Grid.Row="0" Grid.Column="0"/>
					<TextBox
						Text="{Binding DetectReleaseA, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="0" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Units}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectUnitAIndex, Mode=TwoWay}"
						Margin="0"
						Width="45"
						Grid.Row="0" Grid.Column="2"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Source}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectSourceBIndex, Mode=TwoWay}"
						Margin="0"
						Width="55"
						Grid.Row="1" Grid.Column="0"/>
					<TextBox
						Text="{Binding DetectReleaseB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Units}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding DetectUnitBIndex, Mode=TwoWay}"
						Margin="0"
						Width="45"
						Grid.Row="1" Grid.Column="2"/>
					<Label 
						Content="保持時間" 
						Margin="0"
						Grid.Row="2" Grid.Column="0"/>
					<TextBox
						Text="{Binding CheckTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_tUnits}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding CheckTimeUnitIndex, Mode=TwoWay}"
						Margin="0"
						Width="45"
						Grid.Row="3" Grid.Column="2"/>
				</Grid>
			</GroupBox>
			<!--Measure設定-->
			<GroupBox
				Header="Measure設定(VI)" 
				Background="LightYellow"
				Margin="0"
				Grid.Row="12" Grid.Column="6"
				Grid.RowSpan="2" Grid.ColumnSpan="3">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="60"/>
						<ColumnDefinition Width="45"/>
						<ColumnDefinition Width="53*"/>
					</Grid.ColumnDefinitions>
					<Grid.ToolTip>
						<ToolTip>
							<TextBlock>
							初期電圧設定経過後、VI測定までの開始時間を入力
							</TextBlock>
						</ToolTip>
					</Grid.ToolTip>
					<Label 
						Content="Stanby"  
						Margin="0"
						Grid.Row="1" Grid.Column="0"/>
					<TextBox  
						Text="{Binding StanbyValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox  
						ItemsSource="{StaticResource ComboItems_tUnits}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding StanbyUnitIndex, Mode=TwoWay}"
						Margin="0" 
						Width="40"
						Grid.Row="1" Grid.Column="3"/>
				</Grid>
			</GroupBox>
			<!--DMM設定 (Normal Sweep時表示)-->
			<GroupBox 
				Header="DMM設定" 
				Background="SkyBlue"
				Grid.Row="7" Grid.Column="0"
				Grid.RowSpan="7" Grid.ColumnSpan="6">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="50"/>
						<ColumnDefinition Width="55"/>
						<ColumnDefinition Width="55"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="50"/>
					</Grid.ColumnDefinitions>
					<Label 
						Content="Measure"  
						Margin="0"
						Grid.Row="0" Grid.Column="1"/>
					<Label 
						Content="Range"  
						Margin="0"
						Grid.Row="0" Grid.Column="2"/>
					<Label 
						Content="NPLC"  
						Margin="0"
						Grid.Row="0" Grid.Column="3"/>
					<Label 
						Content="Disp.ON"  
						Margin="0"
						Grid.Row="0" Grid.Column="4"/>
					<Label 
						Content="DMM1"
						Grid.Row="1" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasMode1Index, Mode=TwoWay, FallbackValue=0}" 
						Margin="5,0,0,0"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasRang1Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="1" Grid.Column="2"/>
					<TextBox 
						Text="{Binding Meas1plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="3"/>
					<CheckBox 
						IsChecked="{Binding Meas1DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="1" Grid.Column="4"/>
					<Label 
						Content="DMM2"  
						Grid.Row="2" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasMode2Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="2" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasRang2Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="2" Grid.Column="2"/>
					<TextBox 
						Text="{Binding Meas2plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="2" Grid.Column="3"/>
					<CheckBox 
						IsChecked="{Binding Meas2DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="2" Grid.Column="4"/>
					<Label 
						Content="DMM3"  
						Grid.Row="3" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasMode3Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasRang3Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="3" Grid.Column="2"/>
					<TextBox
						Text="{Binding Meas3plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="3" Grid.Column="3"/>
					<CheckBox
						IsChecked="{Binding Meas3DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="3" Grid.Column="4"/>
					<Label 
						Content="DMM4"  
						Grid.Row="4" Grid.Column="0"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Mode}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasMode4Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="4" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasRang4Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="4" Grid.Column="2"/>
					<TextBox
						Text="{Binding Meas4plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="4" Grid.Column="3"/>
					<CheckBox
						IsChecked="{Binding Meas4DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="4" Grid.Column="4"/>
					<Label 
						Content="TRIG"  
						Grid.Row="5" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_dmmTrigSource}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding MeasTrigIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="5" Grid.Column="1"
						Grid.ColumnSpan="2"/>
				</Grid>
			</GroupBox>
			<!--Save,Load,プリセットボタン-->
			<Grid
				Grid.Row="15" Grid.Column="0"
				Grid.ColumnSpan="9">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="100"/>
				</Grid.ColumnDefinitions>
				<Button
					Content="測定条件Save"
					Command="{Binding DataContext.SaveUserConfigCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
					Width="90"
					Height="40"
					Margin="5"
					Grid.Row="0" Grid.Column="0"/>
				<Button 
					Content="測定条件Load"
					Command="{Binding DataContext.LoadUserConfigCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Converter={StaticResource PresetAndTabParameterConverter}}"
					Width="90"
					Height="40"
					Margin="5"
					Grid.Row="0" Grid.Column="1"/>
				<Button
					x:Name ="PresetButton"
					Content="プリセット一覧"
					Command="{Binding DataContext.OpenPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
					CommandParameter="{Binding}"
					Width="90"
					Height="40"
					Margin="5"
					Grid.Row="0" Grid.Column="2"/>
				<!-- プリセットポップアップ -->
				<Popup 
					IsOpen="{Binding DataContext.IsPopupOpen, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
					PlacementTarget="{Binding ElementName=PresetButton}"
					Placement="Right"
					AllowsTransparency="True"
					PopupAnimation="Slide"
					HorizontalOffset="5">
					<Border Background="White" 
                        BorderBrush="Gray" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="10">
						<ScrollViewer 
							MaxHeight="200" 
							VerticalScrollBarVisibility="Auto">
							<StackPanel>
								<!-- プリセット -->
								<ItemsControl ItemsSource="{Binding DataContext.FilteredPresetButtons, RelativeSource={RelativeSource AncestorType=Window}}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Button 
												Content="{Binding Name}" 
												Command="{Binding DataContext.SelectPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
												CommandParameter="{Binding}"
												Tag="{Binding Id}"
												Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}}"
												Margin="5,2" 
												Width="120"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</ScrollViewer>
					</Border>
				</Popup>
			</Grid>
		</Grid>
	</DataTemplate>
</ResourceDictionary>