						Margin="0" 
						Width="45"
						Grid.Row="6" Grid.Column="2"/>
				</Grid>
			</GroupBox>
			<!--PG設定 (Normal Sweep時非表示)-->
			<GroupBox
				Header="PG設定(PulseGenCheck時有効)" 
				Background="GreenYellow"
				Visibility="{Binding NormalSweepCheck, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
				IsEnabled="{Binding PulseGenUseCheck}"
				Margin="0"
				Grid.Row="7" Grid.Column="3"
				Grid.RowSpan="8" Grid.ColumnSpan="3">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="62*"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="50*"/>
					</Grid.ColumnDefinitions>
					<Label 
						Content="OUTP CH"
						Grid.Row="0" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_OutputCH}"
						IsReadOnly="True"
						SelectedIndex="{Binding PulseGenConfig.OutputChIndex, Mode=TwoWay, FallbackValue=1}"
						Margin="0"  
						Width="47"
						Grid.Row="0" Grid.Column="1"
						Grid.ColumnSpan="2">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock 
									Text="{Binding Name}"
									Background="{Binding Tag, Converter={StaticResource TagToBrushConverter}}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
					<Label 
						Content="Low Lev." 
						Grid.Row="1" Grid.Column="0">
						<Label.ToolTip>
							<ToolTip>
								<TextBlock>
								Limit値を入力
								</TextBlock>
							</ToolTip>
						</Label.ToolTip>
					</Label>
					<TextBox 
						Text="{Binding PulseGenConfig.LowValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Units}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding PulseGenConfig.LowVUnitIndex, Mode=TwoWay, FallbackValue=1}"
						Margin="0" 
						Width="45"
						Grid.Row="1" Grid.Column="2"/>
					<Label 
						Content="High Lev." 
						Grid.Row="2" Grid.Column="0">
						<Label.ToolTip>
							<ToolTip>
								<TextBlock>
								Limit値を入力
								</TextBlock>
							</ToolTip>
						</Label.ToolTip>
					</Label>
					<TextBox 
						Text="{Binding PulseGenConfig.HighValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="2" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Units}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding PulseGenConfig.HighVUnitIndex, Mode=TwoWay, FallbackValue=1}"
						Margin="0" 
						Width="45"
						Grid.Row="2" Grid.Column="2"/>
					<Label 
						Content="出力極性" 
						Grid.Row="3" Grid.Column="0">
						<Label.ToolTip>
							<ToolTip>
								<TextBlock>
								"Normal"を選択した場合HighLev.を+方向にSweep<LineBreak/>
								"Inverted"を選択した場合LowLev.を-方向にSweep
								</TextBlock>
							</ToolTip>
						</Label.ToolTip>
					</Label>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Polarity}"
						DisplayMemberPath="Name"
						IsReadOnly="True"
						SelectedIndex="{Binding PulseGenConfig.PolarityIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="70"
						Grid.Row="3" Grid.Column="1"
						Grid.ColumnSpan="2"/>
					<Label 
						Content="Period" 
						Grid.Row="4" Grid.Column="0"/>
					<TextBox 
						Text="{Binding PulseGenConfig.PeriodValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="4" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_tUnits}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding PulseGenConfig.PeriodUnitIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0"  
						Width="45"
						Grid.Row="4" Grid.Column="2"/>
					<Label 
						Content="Width" 
						Grid.Row="5" Grid.Column="0">
						<Label.ToolTip>
							<ToolTip>
								<TextBlock>
								出力極性"Normal"の場合HighLev.区間の幅<LineBreak/>
								出力極性"Inverted"の場合LowLev.区間の幅
								</TextBlock>
							</ToolTip>
						</Label.ToolTip>
					</Label>
					<TextBox 
						Text="{Binding PulseGenConfig.WidthValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="5" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_tUnits}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding PulseGenConfig.WidthUnitIndex, Mode=TwoWay, FallbackValue=1}"
						Margin="0"  
						Width="45"
						Grid.Row="5" Grid.Column="2"/>
					<Label 
						Content="OUTP Z" 
						Grid.Row="6" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_OutputZ}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding PulseGenConfig.OutputLoadIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="0" 
						Width="60"
						Grid.Row="6" Grid.Column="1"
						Grid.ColumnSpan="2"/>
				</Grid>
			</GroupBox>
			<!--DMM設定 (Normal Sweep時表示)-->
			<GroupBox 
				Header="DMM設定" 
				Background="SkyBlue"
				Visibility="{Binding NormalSweepCheck, Converter={StaticResource BooleanToVisibility}}"
				Grid.Row="7" Grid.Column="0"
				Grid.RowSpan="7" Grid.ColumnSpan="6">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
						<RowDefinition Height="25"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="50"/>
						<ColumnDefinition Width="55"/>
						<ColumnDefinition Width="55"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="50"/>
					</Grid.ColumnDefinitions>
					<Label 
						Content="Measure"  
						Margin="0"
						Grid.Row="0" Grid.Column="1"/>
					<Label 
						Content="Range"  
						Margin="0"
						Grid.Row="0" Grid.Column="2"/>
					<Label 
						Content="NPLC"  
						Margin="0"
						Grid.Row="0" Grid.Column="3"/>
					<Label 
						Content="Disp.ON"  
						Margin="0"
						Grid.Row="0" Grid.Column="4"/>
					<Label 
						Content="DMM1"
						Grid.Row="1" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasMode1Index, Mode=TwoWay, FallbackValue=0}" 
						Margin="5,0,0,0"
						Grid.Row="1" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasRang1Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="1" Grid.Column="2"/>
					<TextBox 
						Text="{Binding DmmConfig.Meas1plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="1" Grid.Column="3"/>
					<CheckBox 
						IsChecked="{Binding DmmConfig.Meas1DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="1" Grid.Column="4"/>
					<Label 
						Content="DMM2"  
						Grid.Row="2" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasMode2Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="2" Grid.Column="1"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasRang2Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="2" Grid.Column="2"/>
					<TextBox 
						Text="{Binding DmmConfig.Meas2plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="2" Grid.Column="3"/>
					<CheckBox 
						IsChecked="{Binding DmmConfig.Meas2DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="2" Grid.Column="4"/>
					<Label 
						Content="DMM3"  
						Grid.Row="3" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_Mode}"
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasMode3Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="3" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasRang3Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="3" Grid.Column="2"/>
					<TextBox
						Text="{Binding DmmConfig.Meas3plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="3" Grid.Column="3"/>
					<CheckBox
						IsChecked="{Binding DmmConfig.Meas3DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="3" Grid.Column="4"/>
					<Label 
						Content="DMM4"  
						Grid.Row="4" Grid.Column="0"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_Mode}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasMode4Index, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="4" Grid.Column="1"/>
					<ComboBox
						ItemsSource="{StaticResource ComboItems_MeasureRang}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasRang4Index, Mode=TwoWay, FallbackValue=0}"
						Grid.Row="4" Grid.Column="2"/>
					<TextBox
						Text="{Binding DmmConfig.Meas4plc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Grid.Row="4" Grid.Column="3"/>
					<CheckBox
						IsChecked="{Binding DmmConfig.Meas4DispOn, Mode=TwoWay}"
						Margin="15,0,0,0"
						Grid.Row="4" Grid.Column="4"/>
					<Label 
						Content="TRIG"  
						Grid.Row="5" Grid.Column="0"/>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_dmmTrigSource}" 
						DisplayMemberPath="Name" 
						IsReadOnly="True"
						SelectedIndex="{Binding DmmConfig.MeasTrigIndex, Mode=TwoWay, FallbackValue=0}"
						Margin="5,0,0,0"
						Grid.Row="5" Grid.Column="1"
						Grid.ColumnSpan="2"/>
				</Grid>
			</GroupBox>
			<!--Save,Load,プリセットボタン-->
			<Grid
				Grid.Row="15" Grid.Column="0"
				Grid.ColumnSpan="9">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="100"/>
					<ColumnDefinition Width="100"/>
				</Grid.ColumnDefinitions>
				<Button
					Content="条件Save"
					Command="{Binding DataContext.SaveUserConfigCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
					Width="90"
					Height="35"
					Margin="5"
					Grid.Row="0" Grid.Column="0"/>
				<Button
					Content="条件Save(全Tab)"
					Command="{Binding DataContext.SaveAllUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
					Width="90"
					Height="35"
					Margin="5"
					Grid.Row="1" Grid.Column="0"/>
				<Button 
					Content="条件Load"
					Command="{Binding DataContext.LoadUserConfigCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Converter={StaticResource PresetAndTabParameterConverter}}"
					Width="90"
					Height="35"
					Margin="5"
					Grid.Row="0" Grid.Column="1"/>
				<Button
					Content="条件Load(全Tab)"
					Command="{Binding DataContext.LoadAllUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
					Width="90"
					Height="35"
					Margin="5"
					Grid.Row="1" Grid.Column="1"/>
				<Button
					x:Name ="PresetButton"
					Content="プリセット一覧"
					Command="{Binding DataContext.OpenPresetPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
					CommandParameter="{Binding}"
					Width="90"
					Height="75"
					Margin="5"
					Grid.Row="0" Grid.Column="2"
					Grid.RowSpan="2"/>
				<!-- プリセットポップアップ -->
				<Popup 
					IsOpen="{Binding DataContext.IsPopupOpen, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
					PlacementTarget="{Binding ElementName=PresetButton}"
					Placement="Right"
					AllowsTransparency="True"
					PopupAnimation="Slide"
					HorizontalOffset="5">
					<Border Background="White" 
                        BorderBrush="Gray" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="10">
						<ScrollViewer 
							MaxHeight="200" 
							VerticalScrollBarVisibility="Auto">
							<StackPanel>
								<!-- プリセット -->
								<ItemsControl ItemsSource="{Binding DataContext.FilteredPresetButtons, RelativeSource={RelativeSource AncestorType=Window}}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Button 
												Content="{Binding Name}" 
												Command="{Binding DataContext.SelectPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
												CommandParameter="{Binding}"
												Tag="{Binding Id}"
												Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}}"
												Margin="5,2" 
												Width="120"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</ScrollViewer>
					</Border>
				</Popup>
			</Grid>
		</Grid>
	</DataTemplate>
</ResourceDictionary>