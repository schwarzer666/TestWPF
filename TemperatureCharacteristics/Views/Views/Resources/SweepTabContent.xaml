							<DataTemplate>
								<TextBlock 
									Text="{Binding Name}"
									Background="{Binding Tag, Converter={StaticResource TagToBrushConverter}}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
					<ComboBox 
						ItemsSource="{StaticResource ComboItems_TrigDirectional}"
