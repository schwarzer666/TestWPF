<UserControl x:Class="TemperatureCharacteristics.Views.Controls.SaveLoadPresetPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TemperatureCharacteristics.Views.Controls">
	
	<!--ContentPresenter の DataContext（＝タブの ViewModel）を継承する-->
	<UserControl.DataContext>
		<Binding RelativeSource="{RelativeSource AncestorType=ContentPresenter}"/>
	</UserControl.DataContext>

	<Grid Background="LightGreen">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="100"/>
			<ColumnDefinition Width="100"/>
			<ColumnDefinition Width="100"/>
		</Grid.ColumnDefinitions>

		<!-- Save -->
		<Button 
            x:Name="SaveButton"
            Content="測定条件Save"
            Command="{Binding DataContext.OpenSavePopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            CommandParameter="{Binding}"
            Style="{StaticResource CardButtonStyle}"
            Width="90"
            Height="40"
            Margin="5"
            Grid.Column="0"/>

		<!-- Load -->
		<Button
            x:Name="LoadButton"
            Content="測定条件Load"
            Command="{Binding DataContext.OpenLoadPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            CommandParameter="{Binding}"
            Style="{StaticResource CardButtonStyle}"
            Width="90"
            Height="40"
            Margin="5"
            Grid.Column="1"/>

		<!-- Preset -->
		<Button
            x:Name="PresetButton"
            Content="プリセット一覧"
            Command="{Binding DataContext.OpenPresetPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            CommandParameter="{Binding}"
            Style="{StaticResource CardButtonStyle}"
            Width="90"
            Height="40"
            Margin="5"
            Grid.Column="2"/>

		<!-- Save Popup -->
		<Popup 
            IsOpen="{Binding DataContext.IsSavePopupOpen, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
            PlacementTarget="{Binding ElementName=SaveButton}"
            Placement="Right"
            AllowsTransparency="True"
            PopupAnimation="Slide"
            HorizontalOffset="5">

			<Border Background="#FAFAFA"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Effect="{StaticResource PopupShadow}">

				<StackPanel Width="150">
					<TextBlock Text="保存操作"
                               FontWeight="Bold"
                               Margin="5,0,5,10"
                               Foreground="#444"/>

					<UniformGrid Columns="1" Rows="2">
						<Button 
                            Content="このタブのみSave"
                            Command="{Binding DataContext.SaveUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource CardButtonStyle}"
                            Width="160"
                            Margin="5"/>

						<Button 
                            Content="全タブSave"
                            Command="{Binding DataContext.SaveAllUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource CardButtonStyle}"
                            Width="160"
                            Margin="5"/>
					</UniformGrid>
				</StackPanel>
			</Border>
		</Popup>

		<!-- Load Popup -->
		<Popup 
            IsOpen="{Binding DataContext.IsLoadPopupOpen, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
            PlacementTarget="{Binding ElementName=LoadButton}"
            Placement="Right"
            AllowsTransparency="True"
            PopupAnimation="Slide"
            HorizontalOffset="5">

			<Border Background="#FAFAFA"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Effect="{StaticResource PopupShadow}">

				<StackPanel Width="150">
					<TextBlock Text="読込操作"
                               FontWeight="Bold"
                               Margin="5,0,5,10"
                               Foreground="#444"/>

					<UniformGrid Columns="1" Rows="2">
						<Button 
                            Content="このタブにLoad"
                            Command="{Binding DataContext.LoadUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource CardButtonStyle}"
                            Width="160"
                            Margin="5"/>

						<Button 
                            Content="全タブLoad"
                            Command="{Binding DataContext.LoadAllUserConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource CardButtonStyle}"
                            Width="160"
                            Margin="5"/>
					</UniformGrid>
				</StackPanel>
			</Border>
		</Popup>

		<!-- Preset Popup -->
		<Popup 
            IsOpen="{Binding DataContext.IsPresetPopupOpen, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
            PlacementTarget="{Binding ElementName=PresetButton}"
            Placement="Right"
            AllowsTransparency="True"
            PopupAnimation="Slide"
            HorizontalOffset="5">

			<Border Background="#FAFAFA"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Effect="{StaticResource PopupShadow}">

				<ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
					<StackPanel Width="200">
						<ItemsControl ItemsSource="{Binding DataContext.FilteredPresetButtons, RelativeSource={RelativeSource AncestorType=Window}}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Button 
                                        Content="{Binding Name}"
                                        Command="{Binding DataContext.SelectPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Tag="{Binding Id}"
                                        Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}}"
                                        Style="{StaticResource CardButtonStyle}"
                                        Width="160"
                                        Margin="5,2"/>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</ScrollViewer>
			</Border>
		</Popup>

	</Grid>
</UserControl>
